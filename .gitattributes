# Keep packaged tarballs (Packagist downloads) small by stripping dev-only files
/.github              export-ignore
/.gitattributes       export-ignore
/.gitignore           export-ignore
/.php-cs-fixer.php    export-ignore
/.phpstan.dist.neon   export-ignore
/.rector.php          export-ignore

# Enforce LF line endings on checkout so the line-endings CI gate never fails
*.css   text eol=lf
*.html  text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.php   text eol=lf
*.phtml text eol=lf
*.sh    text eol=lf
*.sql   text eol=lf
*.svg   text eol=lf
*.txt   text eol=lf
*.xml   text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf