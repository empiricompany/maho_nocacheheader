<?xml version="1.0"?>
<config>
    <sections>
        <web>
            <groups>
                <nocacheheader translate="label">
                    <label>Cache-Control Header</label>
                    <sort_order>100</sort_order>
                    <show_in_default>1</show_in_default>
                    <show_in_website>1</show_in_website>
                    <show_in_store>1</show_in_store>
                    <fields>
                        <add_nocache_header translate="label comment">
                            <label>Add Cache-Control: no-store, no-cache, must-revalidate and Pragma: no-cache headers</label>
                            <comment>When enabled, adds Cache-Control: no-store, no-cache, must-revalidate and Pragma: no-cache to all frontend pages only. Restores the default behavior from OpenMage. Does NOT affect the admin panel.</comment>
                            <frontend_type>select</frontend_type>
                            <source_model>adminhtml/system_config_source_yesno</source_model>
                            <sort_order>10</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                        </add_nocache_header>
                    </fields>
                </nocacheheader>
            </groups>
        </web>
    </sections>
</config>
